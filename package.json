{
  "name": "touch-grass",
  "version": "1.3.0",
  "main": "main.js",
  "author": "Harish <rengarajharish@gmail.com>",
  "description": "A productivity break reminder desktop application to remind you to Touch Grass.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reharish/touch-grass.git"
  },
  "scripts": {
    "start": "electron . --no-sandbox",
    "package": "electron-builder --linux"
  },
  "build": {
    "appId": "com.touchgrass.app",
    "productName": "touch-grass",
    "executableName": "touch-grass",
    "publish": {
      "provider": "github",
      "owner": "reharish",
      "repo": "touch-grass"
    },
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icons",
      "desktop": {
        "Name": "Touch Grass",
        "Comment": "A productivity break reminder desktop application to remind you to Touch Grass.",
        "StartupWMClass": "touch-grass"
      }
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
